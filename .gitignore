# =============================================
# Unity
# =============================================

# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]serSettings/

# Memory Profiler Snapshots
[Mm]emoryCaptures/

# Recordings
[Rr]ecordings/

# Asset Store downloads
AssetStoreTools*

# IDE auto-generated project files (Unity regenerates them)
*.csproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.vcxproj
*.vcxproj.filters
*.vcxproj.user

# Re-enable the specific project files that should be tracked
!ToolProject/**/*.csproj
!ToolProject/**/*.sln
!ToolProject/**/*.vcxproj
!ToolProject/**/*.vcxproj.filters
!ToolProject/**/*.vcxproj.user

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crashlytics
sysinfo.txt

