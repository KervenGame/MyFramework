# =============================================
# Git LFS - Large binary assets
# =============================================

# Audio
*.mp3 filter=lfs diff=lfs merge=lfs -text
*.ogg filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
*.aif filter=lfs diff=lfs merge=lfs -text
*.aiff filter=lfs diff=lfs merge=lfs -text

# Video
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text
*.avi filter=lfs diff=lfs merge=lfs -text
*.webm filter=lfs diff=lfs merge=lfs -text

# Textures & Images (large binary)
*.psd filter=lfs diff=lfs merge=lfs -text
*.tga filter=lfs diff=lfs merge=lfs -text
*.exr filter=lfs diff=lfs merge=lfs -text
*.hdr filter=lfs diff=lfs merge=lfs -text

# 3D Models
*.fbx filter=lfs diff=lfs merge=lfs -text
*.obj filter=lfs diff=lfs merge=lfs -text
*.max filter=lfs diff=lfs merge=lfs -text
*.blend filter=lfs diff=lfs merge=lfs -text
*.dae filter=lfs diff=lfs merge=lfs -text
*.mb filter=lfs diff=lfs merge=lfs -text
*.ma filter=lfs diff=lfs merge=lfs -text
*.3ds filter=lfs diff=lfs merge=lfs -text

# Unity Asset Bundles & Packages
*.unitypackage filter=lfs diff=lfs merge=lfs -text
*.bundle filter=lfs diff=lfs merge=lfs -text

# DLLs & Native Plugins
*.dll filter=lfs diff=lfs merge=lfs -text
*.so filter=lfs diff=lfs merge=lfs -text
*.dylib filter=lfs diff=lfs merge=lfs -text
*.a filter=lfs diff=lfs merge=lfs -text

# Fonts (binary)
*.ttf filter=lfs diff=lfs merge=lfs -text
*.otf filter=lfs diff=lfs merge=lfs -text

# =============================================
# Text files - force LF line endings
# =============================================

# Source code
*.cs text diff=csharp
*.js text
*.ts text
*.py text
*.cpp text
*.h text
*.c text
*.hpp text
*.java text
*.kt text

# Unity scene & prefab (YAML-based)
*.unity text merge=unityyamlmerge
*.prefab text merge=unityyamlmerge
*.asset text
*.meta text
*.controller text
*.overrideController text
*.mask text
*.anim text
*.mat text
*.physicsMaterial text
*.physicsMaterial2D text
*.renderTexture text
*.lighting text
*.guiskin text
*.fontsettings text
*.spriteatlas text
*.playable text
*.signal text

# Shaders
*.shader text
*.cginc text
*.hlsl text
*.cg text
*.glslinc text
*.raytrace text

# Configuration
*.json text
*.xml text
*.yaml text
*.yml text
*.txt text
*.csv text
*.cfg text
*.ini text
*.rsp text
*.asmdef text

# Web
*.html text
*.css text
*.htm text

# Build scripts
*.gradle text
*.bat text eol=crlf
*.sh text eol=lf
*.cmd text eol=crlf
*.properties text

# Project files
*.sln text eol=crlf
*.csproj text
*.vcxproj text
*.vcxproj.filters text

# =============================================
# Binary files
# =============================================

*.png binary
*.jpg binary
*.jpeg binary
*.bmp binary
*.gif binary
*.ico binary
*.tif binary
*.tiff binary
*.webp binary
